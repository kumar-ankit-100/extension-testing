{
  "name": "careeros-extension",
  "displayName": "CareerOS — AI Career Operating System",
  "version": "0.1.0",
  "description": "Track job applications, manage resumes, and supercharge your job hunt with AI.",
  "author": "CareerOS",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/chrome-extension": "^1.3.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.451.0",
    "plasmo": "^0.90.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-dropzone": "^14.2.10",
    "tailwind-merge": "^2.5.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.3.1",
    "@types/chrome": "0.0.277",
    "@types/node": "22.7.5",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "prettier": "3.3.3",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.6.3"
  },
  "manifest": {
    "name": "CareerOS",
    "permissions": [
      "storage",
      "activeTab",
      "tabs",
      "cookies"
    ],
    "host_permissions": [
      "http://*/*",
      "https://*/*",
      "https://*.clerk.accounts.dev/*",
      "https://clerk.*.com/*"
    ],
    "key": "$CRX_PUBLIC_KEY"
  }
}
